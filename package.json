{
  "name": "soulforge",
  "version": "0.1.0",
  "private": true,
  "description": "A forge for agents. Soul, tools, endpoints, memory, eval.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint memory/**/*.ts endpoints/examples/url-inspector-with-memory/**/*.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate-souls": "node souls/validate.mjs",
    "memory:example": "tsx memory/examples/reflect-session.ts",
    "url-inspector-memory:example": "tsx endpoints/examples/url-inspector-with-memory/src/demo.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.10.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
